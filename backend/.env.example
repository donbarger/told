# Server
PORT=3002
FRONTEND_URL=http://localhost:5175
BACKEND_URL=http://localhost:3002

# Sessions
JWT_SECRET=change-me-in-production

# Google OAuth 2.0
# Register at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BACKEND_URL}/api/auth/google/callback
# Authorized JS origin:    ${FRONTEND_URL}
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin access — comma-separated emails
ADMIN_EMAILS=you@example.com

# AI scene generation (https://openrouter.ai/)
OPENROUTER_API_KEY=

# Optional: self-hosted TTS (Kokoro-compatible endpoint)
# TTS_SERVER_URL=http://localhost:8787
# HF_TTS_VOICE=am_michael
